{
  "name": "quick-test-example",
  "version": "1.0.0",
  "type": "module",
  "main": "app.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node app.js",
    "start": "node app.js",
    "start:secure": "AIKIDO_BLOCK=true node app.js",
    "test": "cross-env NODE_ENV=test OPENWEATHER_API_KEY=test-api-token mocha --reporter mocha-sonarqube-reporter --reporter-options output=xunit.xml test --exit",
    "cover": "cross-env NODE_ENV=test OPENWEATHER_API_KEY=test-api-token c8 --reporter=text --reporter=lcov --reporter=html mocha --exit",
    "precover": "rimraf .nyc_output coverage",
    "postcover": "node scripts/coverage-makeover.js"
  },
  "author": "Nova Ferrydianto <novaferrydianto@gmail.com>",
  "license": "ISC",
  "devDependencies": {
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "cross-env": "^10.1.0",
    "fast-check": "^4.7.0",
    "mocha": "^11.7.5",
    "mocha-sonarqube-reporter": "1.0.2",
    "mochawesome": "^7.1.3",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "sinon": "^21.1.2",
    "snyk-to-html": "^3.7.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "@aikidosec/firewall": "^1.8.23",
    "colors": "^1.4.0",
    "command-line-args": "^6.0.2",
    "dotenv": "^17.4.2",
    "node-fetch": "^3.3.2"
  },
  "c8": {
    "all": true,
    "include": [
      "*.js",
      "src/**/*.js"
    ],
    "exclude": [
      "test/**",
      "node_modules/**",
      "coverage/**"
    ],
    "reporter": [
      "text",
      "lcov",
      "html"
    ],
    "report-dir": "coverage",
    "all-files": true
  },
  "overrides": {
    "serialize-javascript": "^7.0.3",
    "mocha": {
      "diff": "^8.0.4",
      "minimatch": {
        ".": "^9.0.6",
        "brace-expansion": "^2.0.3"
      }
    }
  }
}
