{
  "name": "quick-test-example",
  "version": "1.0.0",
  "type": "module",
  "main": "app.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node app.js",
    "start": "node app.js",
    "start:secure": "AIKIDO_BLOCK=true node app.js",
    "test": "cross-env OPENWEATHER_API_KEY=test-api-token mocha --reporter mocha-sonarqube-reporter --reporter-options output=xunit.xml test --exit",
    "cover": "cross-env OPENWEATHER_API_KEY=test-api-token NODE_OPTIONS=--experimental-vm-modules nyc --reporter=text --reporter=lcov mocha --exit",
    "precover": "rm -rf .nyc_output coverage"
  },
  "author": "Nova Ferrydianto <novaferrydianto@gmail.com>",
  "license": "ISC",
  "devDependencies": {
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "cross-env": "^10.1.0",
    "mocha": "^11.7.5",
    "mocha-sonarqube-reporter": "1.0.2",
    "mochawesome": "^7.1.3",
    "nyc": "^18.0.0",
    "sinon": "^21.1.1",
    "source-map-support": "^0.5.21"
  },
  "dependencies": {
    "@aikidosec/firewall": "^1.8.22",
    "colors": "^1.4.0",
    "command-line-args": "^6.0.2",
    "dotenv": "^17.4.1",
    "node-fetch": "^3.3.2"
  },
  "nyc": {
    "all": true,
    "include": [
      "*.js",
      "src/**/*.js"
    ],
    "exclude": [
      "test",
      "node_modules"
    ],
    "reporter": [
      "text",
      "lcov",
      "html"
    ],
    "report-dir": "coverage",
    "extension": [
      ".js",
      ".mjs"
    ],
    "require": [
      "source-map-support/register"
    ],
    "instrument": true,
    "hookRequire": true,
    "hookRunInContext": true,
    "hookRunInThisContext": true
  },
  "overrides": {
    "serialize-javascript": "^7.0.3",
    "mocha": {
      "diff": "^8.0.4",
      "minimatch": {
        ".": "^9.0.6",
        "brace-expansion": "^2.0.3"
      }
    }
  }
}
