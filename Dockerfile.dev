FROM node:24-alpine@sha256:01743339035a5c3c11a373cd7c83aeab6ed1457b55da6a69e014a95ac4e4700b

WORKDIR /app

# Upgrade OS packages to mitigate vulnerabilities
RUN apk upgrade --no-cache

# Copy package files first
COPY package*.json ./

# Install all dependencies including dev deps (pinned by hash in lockfile)
RUN npm ci

# Copy source code
COPY . .

EXPOSE 3000

CMD ["npx", "nodemon", "--legacy-watch", "app.js"]
