FROM node:24-alpine

WORKDIR /app

# Upgrade OS packages to mitigate vulnerabilities and install nodemon
RUN apk upgrade --no-cache && \
    npm install -g nodemon

# Copy package files first
COPY package*.json ./

# Install all dependencies including dev deps
RUN npm install

# Copy source code
COPY . .

EXPOSE 3000

CMD ["nodemon", "--legacy-watch", "app.js"]
