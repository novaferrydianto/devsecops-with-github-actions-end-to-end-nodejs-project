FROM node:26-alpine@sha256:e71ac5e964b9201072425d59d2e876359efa25dc96bb1768cb73295728d6e4ea

WORKDIR /app

# Upgrade OS packages to mitigate vulnerabilities
RUN apk upgrade --no-cache

# Copy package files first
COPY package*.json ./

# Install all dependencies including dev deps (pinned by hash in lockfile)
RUN npm ci

# Copy source code
COPY . .

EXPOSE 3000

CMD ["npx", "nodemon", "--legacy-watch", "app.js"]
